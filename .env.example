# Copy this file to ".env" and fill in your values.

# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Optional: command prefix for classic (message) commands. Defaults to "!".
COMMAND_PREFIX=!

# Optional: comma-separated guild (server) IDs to sync slash commands to
# instantly during development. Leave empty to sync globally (can take up
# to an hour to appear).
DEV_GUILD_IDS=

# Optional: DeepSeek API key for the /build_server feature (server designer).
# Get one at https://platform.deepseek.com. The bot runs fine without it.
DEEPSEEK_API_KEY=
# Optional overrides (defaults are usually fine):
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: serve the web dashboard on this port (open it in your host panel).
# Leave unset/0 to disable. Reachable at http://<your-server-ip>:<port>/
DASHBOARD_PORT=

# Optional: public address of the dashboard, used by the /dashboard command.
# e.g. http://54.39.221.19:8080
DASHBOARD_URL=

# Required to APPLY settings from the dashboard. Pick a long secret; the
# dashboard asks for it once and sends it with each change. Without it, the
# dashboard is view-only (no one can change your server from the URL).
DASHBOARD_KEY=
