# Copy this file to ".env" and fill in your values.

# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Optional: command prefix for classic (message) commands. Defaults to "!".
COMMAND_PREFIX=!

# Optional: comma-separated guild (server) IDs to sync slash commands to
# instantly during development. Leave empty to sync globally (can take up
# to an hour to appear).
DEV_GUILD_IDS=
